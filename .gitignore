# Dependencies
node_modules/
**/node_modules/
.venv/
__pycache__/
*.egg-info/

# Build output
dist/
build/
frontend/dist/

# ML artifacts (regenerated by scripts/train_model.py)
ml-service/artifacts/*.joblib
ml-service/artifacts/*.json
ml-service/data/*.parquet
ml-service/data/*.csv

# Secrets / local config
.env
.env.*
!.env.example
*.local

# Cryptographic keys / credentials — never commit
*.pem
*.key
*.crt
*.p12
*.pfx
*.keystore
secrets/
backend/keys/
**/credentials.json
**/serviceAccount*.json


# Editor / OS
.DS_Store
.vscode/
.idea/
*.log
.claude
# Sanctions raw/processed data (regenerated by scripts/ingest_sanctions.py)
ml-service/data/raw/
ml-service/data/processed/

# Large datasets (exceed GitHub's 100MB limit; not committed)
datasets/*.zip
datasets/archive.zip

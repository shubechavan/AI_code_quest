# Copy to .env to override. All values have working dev defaults; nothing is required.
PORT=4000
NODE_ENV=development

# ML service (FastAPI) base URL.
ML_SERVICE_URL=http://localhost:8000

# CORS allow-list for the frontend dev server.
FRONTEND_ORIGIN=http://localhost:5173

# Access-token lifetime (minutes) and refresh-token lifetime (days).
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=7

# RS256 signing keys are auto-generated into ./keys on first boot if absent.
# In production these come from a secrets manager, never the repo.
JWT_PRIVATE_KEY_PATH=./keys/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./keys/jwt_public.pem
